datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id       String @id @default(cuid())
  email    String @unique
  password String
  name     String?

  expenses Expense[]
}

model Expense {
  id        String   @id @default(cuid())
  amount    Int
  memo      String?
  imageUrl  String?
  createdAt DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id])
}